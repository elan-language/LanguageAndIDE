# 716cac08d7d1e20705903267cd1fcb4f4120f2acdd7594e5046a959b1e425ae7 Elan 2.0.0-alpha1 valid

main
  call print(factorial(7))
end main

# snipFrom
function factorial(n as Int) returns Int
  return (if(n > 1, n*factorial(n - 1), 1))
end function

# snipTo
test test_factorial
  assert factorial(10) is 3628800
end test
