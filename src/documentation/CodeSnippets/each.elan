# 23a78d75619d2cbac2b2e1b51ab8bc053d4108d02b7f6d8fbe1bcd25ea605514 Elan 2.0.0-alpha guest default_profile valid

main
  variable names set to ["Tom", "Dick", "Harriet"]
  call print(names[0])
  for n in names
    call print(n)
  end for
  call print(reverse("Harriet"))
end main

function reverse(s as String) returns String
  variable sReturn set to ""
  for ch in s
    set sReturn to ch + sReturn
  end for
  return sReturn
end function
