# e010ffeba7d538f63767374107c10d3799c0acd78c6f4da8ce0d77570368ebc0 Elan 2.0.0-alpha valid

# snipFrom
test test_parse
  assert parseAsInt("31") is (true, 31)
  assert parseAsInt("0") is (true, 0)
  assert parseAsInt("thirty one") is (false, 0)
  assert parseAsInt("3.1") is (false, 0)
  assert parseAsFloat("31") is (true, 31)
  assert parseAsFloat("0") is (true, 0)
  assert parseAsFloat("3.1") is (true, 3.1)
end test

# snipTo
main
  variable t set to parseAsInt("3.1")
  variable success set to t.item_0
  variable value set to t.item_1
  call print(t)
  call print("${success}, ${value}")
end main
