# 7b80b9637ff11caa7a5900a31bcac75870417fb240468d5a8d54668db0388ba5 Elan 2.0.0-alpha1 guest default_profile valid

main
  # snipFrom
  for n in range(50, 73)
    variable s set to lambda n as Int => n.toString().length()
    variable np set to pow(2, n).floor()
    call printTab(s(n), $"{n}")
    call printTab(30 - s(np), $"{np}\n")
  end for
  # snipTo
end main
