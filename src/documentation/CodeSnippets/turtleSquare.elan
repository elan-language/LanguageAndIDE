# 811c065d73185d98cfa1240fb2d5858f8b03de06e876287b91eed039a38033ff Elan 2.0.0-alpha guest default_profile valid

main
  # snipFrom
  variable t set to new Turtle()
  call t.placeAt(-75, 50)
  call t.show()
  for i from 1 to 4 + 1 step 1
    call t.turn(90)
    call t.move(80)
    call pause(500)
  end for
  # snipTo
end main
