# 492f3d8efe1d875d47f8be332168bf8464ec9a2288a8bc3ced60893047f50363 Elan 2.0.0-alpha1 valid

main
  constant p set to unicode(0x03c0)
  call testPi(p, 3)
  call testPi(p, 4)
end main

procedure testPi(p as String, v as Float)
  call print(if(pi > v, $"so, {p} > {v}", $"and {p} < {v}"))
end procedure
