# 5d01ad33bacdf96a6217b7aa8b165fd560180ffef7ae7b2815d02d815cc389a8 Elan 2.0.0-alpha guest default_profile valid

main
  # snipFrom
  variable scale set to [262, 294, 330, 349, 392, 440, 494, 523]
  variable scaleL set to scale.length()
  variable quaver set to 250
  variable volume set to 1.5
  for i in range(0, scaleL)
    call tone(quaver, scale[i], volume)
  end for
  call sleep(1)
  for i in range(0, scaleL)
    call tone(quaver, scale[scaleL - 1 - i], volume)
  end for
  # snipTo
end main
