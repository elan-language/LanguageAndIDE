# d8ba5012babace9dfbdf7001c48ce51e09683839ed381b022def8d519a7ace03 Elan 2.0.0-alpha guest default_profile valid

main
  # snipFrom
  variable tab set to 10
  for i from 1 to (tab - 1) + 1 step 1
    variable j set to power(9, i).floor()
    variable f set to (lambda j as Int => j.asString().length())
    call printTab(tab - f(j), $"{j}\n")
  end for
  # snipTo
end main
