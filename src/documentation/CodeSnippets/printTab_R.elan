# 1b5a4a033aa546adcbdb7a815269ef206c5e903e6e405bb741c3f47ef341e51f Elan 2.0.0-alpha1 valid

main
  # snipFrom
  variable tab set to 10
  for i in range(1, tab)
    variable j set to pow(9, i).floor()
    variable f set to (lambda j as Int => j.toString().length())
    call printTab(tab - f(j), $"{j}\n")
  end for
  # snipTo
end main
