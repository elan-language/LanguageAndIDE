# fc36fd88ecc26a592715fa4a161f1931fce218ef8302c3b826c03f1806f4aacc Elan 2.0.0-alpha valid

main
  variable st set to new HashSet<of Int>()
  set st to st.addFromList([3, 5, 7])
  call print(st.length())
  set st to st.add(7)
  call print(st.length())
  set st to st.remove(3)
  call print(st.length())
  set st to st.remove(3)
  call print(st.length())
  call print(st)
end main
