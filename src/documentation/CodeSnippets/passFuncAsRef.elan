# 16977ff0da1e17244746d8dea22ae41b6c7a7c71258f8ce77cae9d916d1294e7 Elan 2.0.0-alpha valid

class Pupil
  constructor()

  end constructor

  function toString() returns String
    return "Pupil"
  end function

  property mathsPercent as Int

end class

main
  variable allPupils set to new List<of Pupil>()
  variable passes set to allPupils.filter(passedMathsTest)
end main

function passedMathsTest(p as Pupil) returns Boolean
  return p.mathsPercent > 35
end function
