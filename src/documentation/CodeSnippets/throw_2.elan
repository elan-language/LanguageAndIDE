# 5f01f839bca6fd8e4b3bb4969f4eb4967163823d84663a42ba2c0ce8a0f4d433 Elan 2.0.0-alpha1 valid

main
  variable a set to (-1.0, 2.0)
  variable b set to (3.0, 6.0)
  variable fQ set to firstQuadrant(a, b)
end main

function firstQuadrant(a as (Float, Float), b as (Float, Float)) returns Float
  if (a.item_0 < 0) or (a.item_1 < 0) or (b.item_0 < 0) or (b.item_1 < 0) then
    throw ElanRuntimeError $"point ({a}) or ({b}) is not in the first quadrant"
  end if
  return 0
end function
