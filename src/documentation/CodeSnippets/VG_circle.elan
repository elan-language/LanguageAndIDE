# ba6ed539e3f55a7a368036ecd508ce74cf5c69b56f0935cf3b2acf0f12eb163c Elan 2.0.0-alpha1 valid

main
  # snipFrom
  variable vg set to new List<of VectorGraphic>()
  variable circ set to new CircleVG()
  call circ.setCentreX(20)
  call circ.setCentreY(20)
  call circ.setRadius(5)
  call circ.setFillColour(green)
  call circ.setStrokeColour(red)
  call circ.setStrokeWidth(2)
  call vg.append(circ)
  call displayVectorGraphics(vg)
  # snipTo
end main
