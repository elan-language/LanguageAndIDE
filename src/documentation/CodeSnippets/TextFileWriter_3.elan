# 037f54a5084eadd8423a025a557b7e4645186d79daac87be5265d24512ea4397 Elan 2.0.0-alpha1 valid

main
  # snipFrom
  variable file set to createFileForWriting("squares.txt")
  for i in range(1, (101))
    call file.writeLine($"{i*i}")
  end for
  try
    call file.saveAndClose()
  catch ElanRuntimeError
    call print("Save cancelled")
  end try
  # snipTo
end main
