# fdbd3cb1fc2068fa337f77930186bd0f59519742054328b74fe8bd63214fd4ad Elan 2.0.0-alpha valid

main
  # snipFrom
  variable file set to createFileForWriting("squares.txt")
  for i in range(1, (101))
    call file.writeLine($"{i*i}")
  end for
  try
    call file.saveAndClose()
  catch ElanRuntimeException
    call print("File save cancelled")
  end try
  # snipTo
end main
