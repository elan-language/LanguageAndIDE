# 8bd290b6f94115388c6abf7b33a3afb791f64198f807f4f462867138119c020f Elan 2.0.0-alpha valid

main
  # snipFrom
  variable p1 set to (4.0, 0)
  variable p2 set to (0, 3.0)
  call print(distanceBetween(p1, p2))
  # snipTo
end main

# snipFrom
function distanceBetween(p1 as (Float, Float), p2 as (Float, Float)) returns Float
  return sqrt(pow(p2.item_0 - p1.item_0, 2) + pow(p2.item_1 - p1.item_1, 2))
end function

# snipTo
