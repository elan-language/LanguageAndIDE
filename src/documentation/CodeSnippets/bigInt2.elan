# 3749da8494fd91d68175e70baa4f4f2044148ff7945c5b35d7f72bfa83976386 Elan 2.0.0-alpha guest default_profile valid

main
  # snipFrom
  for n in range(50, 73)
    variable s set to lambda n as Int => n.asString().length()
    variable np set to power(2, n).floor()
    call printTab(s(n), $"{n}")
    call printTab(30 - s(np), $"{np}\n")
  end for
  # snipTo
end main
