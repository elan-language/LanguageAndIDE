# cb23ad52cf905b40d572020a2633f1480dd2df36b4f26c44aac7e86086e8b914 Elan 2.0.0-alpha1 valid

main
  call print($"{percent(23, 20)}" + "%")
end main

function percent(value as Float, maximum as Float) returns Float
  variable r set to 100.0
  if value > maximum then
    throw ElanRuntimeError "proportion exceeds 100%"
  end if
  return value/maximum*r
end function
