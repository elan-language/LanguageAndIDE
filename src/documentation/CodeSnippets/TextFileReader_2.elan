# dd4d27db80b02c15b44d23b19c75165eba0acfb082fddd68b8a6594bf5b3a4fa Elan 1.7.0 guest default_profile valid

main
  let file be openFileForReading()
  variable lines set to empty List<of String>
  while notfile.endOfFile()
    let line be file.readLine()
    call lines.append(line)
  end while
  print lines
  call file.close()
end main
