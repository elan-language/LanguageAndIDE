# 12fd440680aed54632d92436547fbc18bf05f4d4fafc889a6a562bd4771c7fd1 Elan 2.0.0-alpha guest default_profile valid

main
  # snipFrom
  variable file set to openFileForReading()
  variable lines set to new List<of String>()
  while not file.endOfFile()
    variable line set to file.readLine()
    call lines.append(line)
  end while
  call print(lines)
  call file.close()
  # snipTo
end main
