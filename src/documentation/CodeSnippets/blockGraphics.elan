# 67054bb0b8b28c3033629c708944e4a397f221e841bff2fef44afce8f693fb4b Elan 2.0.0-alpha1 valid

main
  # snipFrom
  variable grid set to createBlockGraphics(white)
  while true
    variable x set to randint(0, 39)
    variable y set to randint(0, 29)
    variable colour set to randint(0, white - 1)
    set grid[x][y] to colour
    call displayBlocks(grid)
  end while
  # snipTo
end main
