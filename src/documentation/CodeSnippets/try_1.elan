# snipFrom
test test_try_1
  try
    call foo()
    call print("not caught")
  catch ElanRuntimeException
    call print(e)
  end try
end test

# snipTo
test test_try_2
  try
    call foo()
    call print("not caught")
  catch ElanRuntimeException
    if not (e.equals("an expected message")) then
      throw ElanRuntimeException e
    end if
  end try
end test

procedure foo()

end procedure
