# b1612ed80abe211bf0c67667a0e455ed01d6070b3a443c9bc8748bc771648582 Elan 2.0.0-alpha5 valid

main
  variable t set to new Turtle()
  call t.placeAt(-100, 75)
  call t.turnToHeading(90)
  for i in rangeInSteps(150, -1, -5)
    call t.move(i)
    call t.turn(90)
    call sleep_ms(300)
  end for
end main
