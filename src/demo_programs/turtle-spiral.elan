# f7f155255bc275bd8495aa2b5b615c270d0e1f245eab0f992622c32cf414f529 Elan 2.0.0-beta1 valid

main
  variable t set to new Turtle()
  call t.placeAt(-100, 75)
  call t.turnToHeading(90)
  for i in rangeInSteps(150, -1, -5)
    call t.move(i)
    call t.turn(90)
    call sleep_ms(300)
  end for
end main
