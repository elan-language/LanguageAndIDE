# 89a5201e8d657f3550ec675bc49c854d44066ebf6aee42be37a6a6c86fccca9d Elan 2.0.0-beta2 valid

main
  variable t set to new Turtle()
  call t.placeAt(-100, 75)
  call t.turnToHeading(90)
  for i in rangeInSteps(150, -1, -5)
    call t.move(i)
    call t.turn(90)
    call sleep_ms(300)
  end for
end main
