# b46f4498e4e97d01baf79ae8ed711d7138d4687e91b231fa4e008e45491fcdda Elan 2.0.0-beta valid

main
  variable t set to new Turtle()
  call t.placeAt(-100, 75)
  call t.turnToHeading(90)
  for i in rangeInSteps(150, -1, -5)
    call t.move(i)
    call t.turn(90)
    call sleep_ms(300)
  end for
end main
