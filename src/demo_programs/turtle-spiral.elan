# dfc6ce00c875408427bb0cb47b7ae487ad1a6e78c77ca6d4ee78e3c1b51156ca Elan 2.0.0-alpha4 valid

main
  variable t set to new Turtle()
  call t.placeAt(-100, 75)
  call t.turnToHeading(90)
  for i in rangeInSteps(150, -1, -5)
    call t.move(i)
    call t.turn(90)
    call sleep_ms(300)
  end for
end main
