# 7618bd35a6634320e97b7f4ae2f389e0a781bbd329f43b9d0e21409b9df49058 Elan 2.0.0-beta-pre1 valid

main
  variable t set to new Turtle()
  call t.placeAt(-100, 75)
  call t.turnToHeading(90)
  for i in rangeInSteps(150, -1, -5)
    call t.move(i)
    call t.turn(90)
    call sleep_ms(300)
  end for
end main
