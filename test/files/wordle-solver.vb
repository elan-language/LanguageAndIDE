<TestMethod> Sub test_incrementCount()
  Dim possAnswer = "BEGAN" ' let
  Dim attempt = "BAGEL" ' let
  Dim d = ["*+*_*":2, "*+*+_":3, "*+*++":0] ' let
  Dim d2 = incrementCount(d, possAnswer, attempt) ' let
  Assert.AreEqual(4, d2["*+*+_"])
  Assert.AreEqual(2, d2["*+*_*"])
  Assert.AreEqual(0, d2["*+*++"])
End Sub

