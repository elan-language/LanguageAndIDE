# e17c1ac62fdf4b1b9ade51a08a108a9b22f70ffcd5a15375f49edf968c6fcc11 Elan 2.0.0-alpha guest default_profile valid

main
  variable r set to new Rule("a", "b", "c", "d", Dir.left)
  call print(r)
end main

enum Dir left, right

class Rule
  constructor(currentState as String, currentSymbol as String, nextState as String, writeSymbol as String, move as Dir)
    set this.currentState to currentState
    set this.currentSymbol to currentSymbol
    set this.nextState to nextState
    set this.writeSymbol to writeSymbol
    set this.move to move
  end constructor

  property currentState as String

  property currentSymbol as String

  property nextState as String

  property writeSymbol as String

  property move as Dir

end class
