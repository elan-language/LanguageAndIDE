# 19cb0563f77206b272cc65679dfdfcb7d6f42952f2e31e0474b07558adf69253 Elan 2.0.0-alpha guest default_profile valid

main
  variable li set to [7, 1, 0, 4, 8, 3, 6]
  call print(li)
  call inPlaceRippleSort(li)
  call print(li)
end main

procedure inPlaceRippleSort(li as List<of Int>)
  variable hasChanged set to true
  variable lastComp set to li.length() - 2
  while hasChanged is true
    set hasChanged to false
    each i in range(0, lastComp + 1)
      if li[i] > li[i + 1] then
        variable temp set to li[i]
        call li.put(i, li[i + 1])
        call li.put(i + 1, temp)
        set hasChanged to true
      end if
    end each
    set lastComp to lastComp - 1
  end while
end procedure
